{
  "expo": {
    "name": "La Soirée des Légendes",
    "slug": "rthom",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",

    "icon": "./assets/icon.png",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1B"
    },

    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.soireelegendes.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "Aucun suivi publicitaire utilisé."
      }
    },

    "android": {
      "package": "com.soireelegendes.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A1B"
      },
      "permissions": []
    },

    "web": {
      "bundler": "metro"
    },

    "plugins": ["expo-font"],

    "extra": {
      "eas": {
        "projectId": "b93fcc95-3ad2-4428-9060-ff28c28c860c"
      }
    }
  }
}
